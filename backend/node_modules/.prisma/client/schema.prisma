generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  email         String?   @unique
  phone         String?
  password      String
  role          String    @default("staff")
  avatar        String?
  isActive      Boolean   @default(true)
  twoFaEnabled  Boolean   @default(false)
  twoFaSecret   String?
  pinHash       String?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?

  orders        Order[]
  shifts        StaffShift[]
  targets       StaffTarget[]
  expenses      Expense[]
  activityLogs  ActivityLog[]
  createdQuotes Quote[]       @relation("QuoteCreator")
  cashBooks     CashBook[]

  @@map("users")
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?
  phone         String?
  address       String?
  notes         String?
  password      String?
  birthday      String?
  loyaltyPoints Int      @default(0)
  totalSpent    Float    @default(0)
  visitCount    Int      @default(0)
  tier          String   @default("bronze")
  favorites     String   @default("[]")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  orders     Order[]
  layaways   Layaway[]
  debts      CustomerDebt[]
  feedback   Feedback[]
  statements CustomerStatement[]

  @@map("customers")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  color       String   @default("#C9A96E")
  createdAt   DateTime @default(now())

  products Product[]

  @@map("categories")
}

model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  contactName   String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  totalSupplied Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  products       Product[]
  transactions   SupplierTransaction[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model Product {
  id                Int      @id @default(autoincrement())
  name              String
  sku               String?  @unique
  barcode           String?  @unique
  categoryId        Int?
  price             Float    @default(0)
  costPrice         Float    @default(0)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  description       String?
  images            String   @default("[]")
  tags              String   @default("[]")
  variants          String   @default("[]")
  supplierId        Int?
  isFeatured        Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  category       Category?       @relation(fields: [categoryId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]

  @@map("products")
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  type      String
  quantity  Int
  reason    String?
  reference String?
  costPrice Float    @default(0)
  userId    Int?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}

model Order {
  id             Int      @id @default(autoincrement())
  orderNumber    String   @unique
  customerId     Int?
  customerName   String?
  customerPhone  String?
  customerEmail  String?
  items          String
  subtotal       Float    @default(0)
  discount       Float    @default(0)
  discountType   String   @default("fixed")
  tax            Float    @default(0)
  total          Float    @default(0)
  paymentMethod  String   @default("cash")
  paymentStatus  String   @default("paid")
  orderStatus    String   @default("completed")
  orderSource    String   @default("pos")
  notes          String?
  servedBy       Int?
  receiptPrinted Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     Customer? @relation(fields: [customerId], references: [id])
  servedByUser User?     @relation(fields: [servedBy], references: [id])
  payments     Payment[]
  refunds      Refund[]

  @@map("orders")
}

model Payment {
  id        Int      @id @default(autoincrement())
  orderId   Int?
  amount    Float
  method    String
  status    String   @default("pending")
  reference String?
  phone     String?
  network   String?
  stripeId  String?
  metadata  String?
  createdAt DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Refund {
  id           Int      @id @default(autoincrement())
  orderId      Int
  orderNumber  String
  reason       String?
  items        String   @default("[]")
  amount       Float    @default(0)
  refundMethod String   @default("cash")
  processedBy  Int?
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("refunds")
}

model Layaway {
  id            Int      @id @default(autoincrement())
  layawayNumber String   @unique
  customerId    Int?
  customerName  String
  customerPhone String?
  items         String   @default("[]")
  totalAmount   Float    @default(0)
  depositPaid   Float    @default(0)
  balanceDue    Float    @default(0)
  dueDate       String?
  status        String   @default("active")
  payments      String   @default("[]")
  notes         String?
  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("layaways")
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float    @default(0)
  category    String   @default("General")
  description String?
  date        String?
  recordedBy  Int?
  createdAt   DateTime @default(now())

  recordedByUser User? @relation(fields: [recordedBy], references: [id])

  @@map("expenses")
}

model DiscountCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  type      String   @default("percent")
  value     Float    @default(0)
  minOrder  Float    @default(0)
  maxUses   Int      @default(0)
  usedCount Int      @default(0)
  isActive  Boolean  @default(true)
  expiresAt String?
  createdAt DateTime @default(now())

  @@map("discount_codes")
}

model SupplierTransaction {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  productId   Int?
  productName String?
  quantity    Int      @default(0)
  unitCost    Float    @default(0)
  totalCost   Float    @default(0)
  notes       String?
  recordedBy  Int?
  createdAt   DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_transactions")
}

model StaffShift {
  id          Int       @id @default(autoincrement())
  userId      Int
  clockIn     DateTime  @default(now())
  clockOut    DateTime?
  hoursWorked Float     @default(0)
  notes       String?

  user User @relation(fields: [userId], references: [id])

  @@map("staff_shifts")
}

model StaffTarget {
  id           Int      @id @default(autoincrement())
  userId       Int
  period       String
  targetSales  Float    @default(0)
  actualSales  Float    @default(0)
  targetOrders Int      @default(0)
  actualOrders Int      @default(0)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("staff_targets")
}

model Quote {
  id            Int      @id @default(autoincrement())
  quoteNumber   String   @unique
  customerId    Int?
  customerName  String?
  customerPhone String?
  customerEmail String?
  items         String   @default("[]")
  subtotal      Float    @default(0)
  discount      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  validUntil    String?
  notes         String?
  status        String   @default("pending")
  createdBy     Int?
  createdAt     DateTime @default(now())

  creator User? @relation("QuoteCreator", fields: [createdBy], references: [id])

  @@map("quotes")
}

model PurchaseOrder {
  id           Int       @id @default(autoincrement())
  poNumber     String    @unique
  supplierId   Int
  items        String    @default("[]")
  totalCost    Float     @default(0)
  status       String    @default("pending")
  expectedDate String?
  receivedAt   DateTime?
  notes        String?
  createdBy    Int?
  createdAt    DateTime  @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("purchase_orders")
}

model CustomerDebt {
  id          Int      @id @default(autoincrement())
  customerId  Int
  amount      Float    @default(0)
  paidAmount  Float    @default(0)
  description String?
  dueDate     String?
  status      String   @default("outstanding")
  payments    String   @default("[]")
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("customer_debts")
}

model CashFloat {
  id        Int      @id @default(autoincrement())
  date      String
  type      String
  amount    Float    @default(0)
  notes     String?
  userId    Int?
  createdAt DateTime @default(now())

  @@map("cash_float")
}

model CashBook {
  id            Int      @id @default(autoincrement())
  type          String // inflow | outflow
  amount        Float
  description   String
  reference     String?
  category      String   @default("General")
  paymentMethod String   @default("cash")
  balance       Float    @default(0)
  userId        Int?
  orderId       Int?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("cash_book")
}

model DailyReconciliation {
  id            Int      @id @default(autoincrement())
  date          String   @unique
  openingFloat  Float    @default(0)
  expectedCash  Float    @default(0)
  countedCash   Float    @default(0)
  variance      Float    @default(0)
  totalSales    Float    @default(0)
  totalExpenses Float    @default(0)
  totalRefunds  Float    @default(0)
  notes         String?
  status        String   @default("pending") // pending | balanced | discrepancy
  reconciledBy  Int?
  createdAt     DateTime @default(now())

  @@map("daily_reconciliations")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  username   String?
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_log")
}

model Setting {
  key       String   @id
  value     String?
  updatedAt DateTime @default(now())

  @@map("settings")
}

model Feedback {
  id           Int      @id @default(autoincrement())
  customerId   Int?
  customerName String?
  rating       Int
  comment      String?
  category     String?
  createdAt    DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("feedback")
}

model CustomerStatement {
  id          Int      @id @default(autoincrement())
  customerId  Int
  type        String
  amount      Float
  description String?
  reference   String?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("customer_statements")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String // low_stock | large_transaction | reconciliation | birthday | debt_due
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  userId    Int?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model OnlineOrder {
  id              Int      @id @default(autoincrement())
  orderNumber     String   @unique
  customerId      Int?
  customerName    String
  customerPhone   String?
  customerEmail   String?
  items           String   @default("[]")
  total           Float    @default(0)
  deliveryAddress String?
  paymentMethod   String   @default("cash_on_delivery")
  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("online_orders")
}
